# ============================================
# VARIÁVEIS DE AMBIENTE - InvestPro
# ============================================
# Adicione estas variáveis nas Secrets do Replit
# Os valores devem ser preenchidos por você
# ============================================

# ===========================================
# OBRIGATÓRIOS - Sistema não funciona sem estes
# ===========================================

# Chave de criptografia para dados sensíveis (32 bytes hex)
ENCRYPTION_KEY=

# Deriv API - Chaves de acesso para trading
DERIV_API_KEY_DEMO=
DERIV_API_KEY_REAL=
DERIV_APP_ID=

# SendGrid - Envio de emails de marketing
SENDGRID_API_KEY=

# Hugging Face - Serviços de IA
HUGGINGFACE_API_KEY=

# Banco de dados PostgreSQL (geralmente fornecido automaticamente pelo Replit)
DATABASE_URL=

# ===========================================
# CONFIGURAÇÕES DO SISTEMA
# ===========================================

# Ambiente da aplicação (development, production)
NODE_ENV=development

# Admin Configuration
ADMIN_EMAIL=admin@example.com
VITE_ADMIN_EMAIL=admin@example.com

# Usuários autorizados do sistema (separados por vírgula)
AUTHORIZED_SYSTEM_USERS=

# Session Secret (mude em produção)
SESSION_SECRET=your-very-secure-session-secret-change-in-production

# ===========================================
# CONFIGURAÇÕES REPLIT
# ===========================================

# Domínios Replit (geralmente preenchido automaticamente)
REPLIT_DOMAINS=
REPLIT_DEV_DOMAIN=
REPL_ID=

# URL base do Replit (para keep-alive e ping)
REPLIT_URL=

# OIDC Issuer URL para autenticação Replit
ISSUER_URL=https://replit.com/oidc

# ===========================================
# OPCIONAIS - Email Service
# ===========================================

# Email via Gmail/Nodemailer
# EMAIL_USER=
# EMAIL_PASS=
# NODEMAILER_EMAIL=your-email@gmail.com
# NODEMAILER_PASSWORD=your-app-password

# ===========================================
# OPCIONAIS - PIX Configuration
# ===========================================

PIX_MERCHANT_NAME=Sua Empresa
PIX_MERCHANT_CITY=Sua Cidade
PIX_KEY=sua-chave-pix

# ===========================================
# OPCIONAIS - Vercel Integration
# ===========================================

# VERCEL_URL=
# VERCEL_ENV=
